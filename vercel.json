{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "about.html", "use": "@vercel/static" },
    { "src": "curriculo.html", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "certificados/**", "use": "@vercel/static" },
    { "src": "styles/**", "use": "@vercel/static" }
  ],
  "routes": [{ "src": "/(.*)", "dest": "/$1" }],
  "outputDirectory": "."
}
