{
  "name": "portifolio",
  "private": true,
  "version": "0.1.0",
  "description": "Site estático de portfólio (HTML/CSS).",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:html": "html-validate \"**/*.html\"",
    "lint:css": "stylelint \"**/*.css\"",
    "lint": "npm run format:check && npm run lint:html && npm run lint:css",
    "prepare": "husky",
    "test": "npm run lint",
    "build": "node ./scripts/build.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.3.1",
    "html-validate": "^10.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
